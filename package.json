{
  "name": "7snawi-store",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api-server dev\" \"pnpm --filter marketplace dev\"",
    "build": "pnpm --filter api-server build && pnpm --filter marketplace build",
    "db:push": "pnpm --filter api-server db:push",
    "db:generate": "pnpm --filter api-server db:generate",
    "db:seed": "pnpm --filter api-server db:seed",
    "db:studio": "pnpm --filter api-server db:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

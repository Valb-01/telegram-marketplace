# =============================================
# TELEGRAM MARKETPLACE - ENVIRONMENT CONFIG
# =============================================

# --- Telegram Bot ---
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here
MINI_APP_URL=https://your-frontend-domain.com

# --- Server ---
PORT=3001
NODE_ENV=development
BACKEND_URL=https://your-backend-domain.com

# --- Payments ---
# Telegram Payments Provider Token (from @BotFather)
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# USDT Wallet Address for payments
USDT_WALLET_ADDRESS=TYourUSDTWalletAddressHere
USDT_NETWORK=TRC20

# Admin Contact Bot
ADMIN_BOT_USERNAME=xri3bot

# --- Security ---
ADMIN_SECRET=your_strong_admin_secret_key_here

# --- File Storage ---
UPLOADS_DIR=./uploads
DIGITAL_FILES_DIR=./digital-files
